# MySQL connection string.
#  - Local dev (docker-compose.yml): mysql://root:tabarca@localhost:3307/tabarca
#  - Hostinger managed MySQL: mysql://USER:PASSWORD@HOST:3306/DBNAME (from hPanel → Databases)
DATABASE_URL=""

# Password for the /admin dashboard.
ADMIN_PASSWORD=""

# Random secret used to sign the admin session cookie (e.g. `openssl rand -hex 32`).
ADMIN_COOKIE_SECRET=""

# Absolute public URL of the app — used for links inside emails.
# e.g. https://tabarca.yourdomain.com (dev: http://localhost:3000)
APP_BASE_URL=""

# SMTP for outgoing email (reservation confirmations, cancellations, lookup).
# Leave SMTP_HOST empty to disable sending — emails are logged to the console.
# Hostinger: create a mailbox in hPanel → Emails, then use:
#   SMTP_HOST=smtp.hostinger.com  SMTP_PORT=465  SMTP_USER=reservas@yourdomain.com
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
# From header, e.g.: Tabarca Boats <reservas@yourdomain.com> (defaults to SMTP_USER)
MAIL_FROM=""
